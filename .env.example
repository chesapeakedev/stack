# Optional: used by the demo app (npm run dev) for certain features.
# Copy to .env and fill in if you need to test those features locally.
# Do not commit .env or real keys.

# Google Maps (Location Input component in demo)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Tenor / GIF search (GifSearch component in demo)
# VITE_TENOR_API_KEY=your_tenor_api_key
